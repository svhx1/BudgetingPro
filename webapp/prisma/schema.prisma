// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String        @id @default(cuid())
  email          String        @unique
  name           String?
  password       String?
  avatarUrl      String?
  failedAttempts Int           @default(0)
  lockedUntil    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  
  transactions Transaction[]
  categories   Category[]
  limits       BudgetLimit[]
  goals        Goal[]
  allocations  BudgetAllocation[]
  monthlySummaries MonthlySummary[]
}

model Category {
  id        String       @id @default(cuid())
  name      String
  color     String       @default("#10b981") // Padrão verde neon
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  transactions Transaction[]
  budgetLimit  BudgetLimit?
  allocations  BudgetAllocation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([name, userId])
}

model BudgetLimit {
  id          String   @id @default(cuid())
  amount      Float
  categoryId  String   @unique
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Transaction {
  id           String   @id @default(cuid())
  description  String
  amount       Float
  type         String   // "INCOME" | "EXPENSE"
  date         DateTime
  paymentMethod String? // "DEBIT" | "CREDIT" (only for EXPENSE)
  
  // Recorrência e Parcelamentos (UUID único por grupo de transações vinculadas)
  groupId      String?
  installment  String?  // Ex: "1/12"
  isGhost      Boolean  @default(false) // Ignora em Dashboards de Ritmo de Gasto, apenas para Extrato.
  
  categoryId   String
  category     Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model VerificationCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, code])
}

model Goal {
  id            String   @id @default(cuid())
  name          String
  targetAmount  Float
  currentAmount Float    @default(0)
  monthlyDeposit Float   @default(0)
  interestRate  Float    @default(0) // taxa mensal (ex: 0.01 = 1%)
  deadline      DateTime?
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model BudgetAllocation {
  id         String   @id @default(cuid())
  amount     Float
  month      Int      // Mês corrente (0-11)
  year       Int      // Ano corrente (ex: 2026)
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([month, year, categoryId, userId]) // Só pode haver um orçamento por categoria em um mês
}

// MATERIALIZED ROLLUP TABLE (Motor Matemático O(1) sugerido para Otimização Extrema)
// Armazena a SOMA exata de todas as transações de um mês específico para leitura Instantânea do front.
model MonthlySummary {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  month            Int      // 1 a 12 (Vamos usar 1-indexed para humano)
  year             Int      // Ex: 2026
  
  totalIncomes     Float    @default(0)
  totalExpenses    Float    @default(0)
  totalCreditUsed  Float    @default(0) // Somente dos expenses onde paymentMethod === "CREDIT"

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([userId, month, year]) // Exclusivo: Cada usuário só tem 1 Summary por Mês/Ano
  @@index([userId, year])          // Leitura veloz indexada
}
